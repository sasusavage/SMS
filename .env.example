# Environment Settings
FLASK_CONFIG=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-secure-secret-key-in-production

# Database Configuration (PostgreSQL 15+ Recommended)
DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/schooldb

# Elite AI Credentials (Sasu AI 2.0)
GROQ_API_KEY=your-groq-llama3-key-for-reasoning
OPENAI_API_KEY=your-openai-whisper-key-for-voice

# WhatsApp Multi-tenancy (Meta Graph API)
WHATSAPP_ACCESS_TOKEN=your-meta-whatsapp-token
WHATSAPP_VERIFY_TOKEN=your-random-verification-token

# SMS Hub (Arkesel Integration)
ARKESEL_SMS_KEY=your-arkesel-api-key
ARKESEL_SMS_SENDER_ID=SmartSchool

# Financial Engine (Paystack)
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# Production Settings (For Deployment)
# FLASK_CONFIG=production
# DATABASE_URL=postgresql://username:password@your-vps-host:5432/nacca_sms
