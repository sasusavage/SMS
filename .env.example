FLASK_CONFIG=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-secure-secret-key-in-production
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: encrypts stored secrets (SMTP/API). Defaults to SECRET_KEY.
# ENCRYPTION_KEY=

# Optional: Redis for shared rate-limit storage across workers
# REDIS_URL=redis://host:6379/0

# Paystack subscription billing (set in Coolify env)
# PAYSTACK_SECRET_KEY=sk_live_xxx
# PAYSTACK_PUBLIC_KEY=pk_live_xxx
# APP_BASE_URL=https://your-app.example.com   # used for the Paystack callback
